# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=chanit

# App
PORT=3000
DEV_MODE=false

# S3-compatible Storage
S3_SERVER=https://s3.eu-central-1.amazonaws.com
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_ATTACHMENTS_BUCKET=chanit-attachments
S3_AVATARS_BUCKET=chanit-avatars

# Email (SMTP)
MAIL_SERVER=mail.chanit.app
MAIL_SERVER_PORT=465
MAIL_USERNAME=chanit-noreply@thimocolditz.de
MAIL_PASSWORD=your-mail-password

# OAuth (Faser)
FASER_CLIENT_ID=your-faser-client-id
FASER_CLIENT_SECRET=your-faser-client-secret

# Discord Webhook
DISCORD_PROTOCOL_WEBHOOK_URL=
